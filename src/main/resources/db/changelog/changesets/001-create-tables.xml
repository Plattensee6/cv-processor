<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-create-cv-processing-requests-table" author="cv-processor">
        <createTable tableName="cv_processing_requests">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="file_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="content_type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="file_size" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="original_content" type="TEXT"/>
            <column name="parsed_text" type="TEXT"/>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="error_message" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="002-create-extracted-fields-table" author="cv-processor">
        <createTable tableName="extracted_fields">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="work_experience_years" type="INTEGER"/>
            <column name="work_experience_details" type="TEXT"/>
            <column name="skills" type="TEXT"/>
            <column name="languages" type="TEXT"/>
            <column name="profile" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="cv_processing_request_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_extracted_fields_cv_processing_request" 
                             referencedTableName="cv_processing_requests" referencedColumnNames="id"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="003-create-validation-results-table" author="cv-processor">
        <createTable tableName="validation_results">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="work_experience_valid" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="work_experience_message" type="TEXT"/>
            <column name="skills_valid" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="skills_message" type="TEXT"/>
            <column name="languages_valid" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="languages_message" type="TEXT"/>
            <column name="profile_valid" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="profile_message" type="TEXT"/>
            <column name="overall_valid" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="extracted_fields_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_validation_results_extracted_fields" 
                             referencedTableName="extracted_fields" referencedColumnNames="id"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="004-create-indexes" author="cv-processor">
        <createIndex tableName="cv_processing_requests" indexName="idx_cv_processing_requests_status">
            <column name="status"/>
        </createIndex>
        <createIndex tableName="cv_processing_requests" indexName="idx_cv_processing_requests_file_name">
            <column name="file_name"/>
        </createIndex>
        <createIndex tableName="extracted_fields" indexName="idx_extracted_fields_cv_processing_request_id">
            <column name="cv_processing_request_id"/>
        </createIndex>
        <createIndex tableName="validation_results" indexName="idx_validation_results_extracted_fields_id">
            <column name="extracted_fields_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
