<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="006-insert-default-hr-role" author="cv-processor">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM roles WHERE name = 'HR'</sqlCheck>
        </preConditions>
        <insert tableName="roles">
            <column name="name" value="HR"/>
            <column name="description" value="HR / Recruiter role for admin dashboard"/>
        </insert>
    </changeSet>
</databaseChangeLog>
