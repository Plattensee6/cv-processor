# Database Configuration
POSTGRES_DB=cvprocessor
POSTGRES_USER=cvuser
POSTGRES_PASSWORD=cvpass
POSTGRES_PORT=5432

# Local Model Configuration (Ollama)
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=120

# Hugging Face Configuration (fallback)
HUGGINGFACE_API_KEY=your-huggingface-api-key-here
HUGGINGFACE_MODEL=openai/gpt-4.1
HUGGINGFACE_MAX_TOKENS=2000
HUGGINGFACE_TEMPERATURE=0.1
HUGGINGFACE_TIMEOUT=60

# Application Configuration
SPRING_PROFILES_ACTIVE=dev
FILE_MAX_SIZE=10MB
FILE_ALLOWED_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Debug Configuration
DEBUG_OPTS=-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005